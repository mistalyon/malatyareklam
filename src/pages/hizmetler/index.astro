---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, categoryLabels, type ServiceCategory } from '../../data/services';

const categories: ServiceCategory[] = ['reklam', 'dijital', 'yeni-nesil'];

const categoryDescs: Record<ServiceCategory, string> = {
  'reklam': 'Klasik ve dijital reklam çözümleriyle markanızı doğru kitleye taşıyoruz.',
  'dijital': 'Arama motoru optimizasyonu, sosyal medya ve e-ticaret ile dijital büyüme.',
  'yeni-nesil': 'Yapay zeka, GEO ve özel yazılım ile geleceğin pazarlama altyapısı.'
};
---

<BaseLayout
  title="Tüm Hizmetlerimiz | Malatya Reklam"
  description="Açıkhava reklam, SEO, web tasarım, e-ticaret, kurumsal yazılım ve AI destekli pazarlama. Malatya'da uçtan uca dijital ve reklam çözümleri."
  keywords="malatya reklam hizmetleri, malatya reklam ajansı hizmetleri, malatya seo hizmeti, malatya web tasarım hizmeti, malatya e-ticaret, malatya yazılım, malatya açıkhava reklam, malatya tabela, malatya sosyal medya yönetimi, malatya google ads"
>
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 text-center max-w-4xl">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">Hizmetlerimiz</span>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 mb-6 leading-tight">
        Markanızı Büyüten <span class="text-apricot-500">14 Hizmet</span>
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed">
        Açıkhava reklamdan yapay zeka destekli içeriğe, SEO'dan kurumsal yazılıma kadar Malatya'da uçtan uca çözümler.
      </p>
    </div>
  </section>

  {categories.map(cat => (
    <section class="py-16 lg:py-20 odd:bg-neutral-50">
      <div class="container mx-auto px-4 lg:px-8">
        <div class="max-w-3xl mb-12">
          <span class="inline-block px-3 py-1 bg-white border border-neutral-200 text-apricot-600 text-xs font-bold uppercase tracking-wider rounded-full mb-3">
            {categoryLabels[cat]}
          </span>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-3">{categoryLabels[cat]}</h2>
          <p class="text-lg text-neutral-600">{categoryDescs[cat]}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.filter(s => s.category === cat).map(service => (
            <a href={`/hizmetler/${service.slug}`} class="group p-6 bg-white border border-neutral-200 rounded-2xl hover:border-apricot-300 hover:shadow-xl hover:shadow-apricot-500/10 hover:-translate-y-1 transition-all">
              <div class="w-12 h-12 rounded-xl bg-apricot-100 flex items-center justify-center text-apricot-600 mb-4 group-hover:bg-apricot-500 group-hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="font-display text-xl font-bold text-neutral-900 mb-2 group-hover:text-apricot-600 transition-colors">{service.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed mb-4">{service.shortDesc}</p>
              <div class="flex items-center gap-2 text-sm font-semibold text-apricot-600">
                İncele
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="py-16 lg:py-20 bg-gradient-to-br from-apricot-500 to-apricot-600 text-white">
    <div class="container mx-auto px-4 lg:px-8 text-center max-w-3xl">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">Projeniz İçin Doğru Hizmeti Bulamadınız mı?</h2>
      <p class="text-xl text-apricot-50 mb-8">İhtiyacınızı bize anlatın, size özel çözüm üretelim.</p>
      <a href="/iletisim" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-apricot-600 font-bold rounded-xl hover:bg-apricot-50 transition-colors text-lg">
        Bizimle İletişime Geçin
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
