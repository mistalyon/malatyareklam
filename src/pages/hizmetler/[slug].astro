---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, categoryLabels } from '../../data/services';
import { getSeoContent } from '../../data/seoContent';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const seo = getSeoContent(service.slug);
const relatedServices = services.filter(s => s.category === service.category && s.slug !== service.slug).slice(0, 3);
const serviceUrl = `https://malatyareklam.com/hizmetler/${service.slug}/`;

// Birleşik FAQ listesi (orijinal + extended)
const allFaqs = seo && seo.extendedFaqs.length > 0
  ? [...service.faqs, ...seo.extendedFaqs.filter(ef => !service.faqs.some(of => of.q === ef.q))]
  : service.faqs;

const serviceSchema: any = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${serviceUrl}#service`,
  "name": service.title,
  "description": service.longDesc,
  "url": serviceUrl,
  "serviceType": categoryLabels[service.category],
  "provider": { "@id": "https://malatyareklam.com/#organization" },
  "areaServed": { "@type": "City", "name": "Malatya" },
  "audience": { "@type": "BusinessAudience", "audienceType": "İşletmeler ve Markalar" }
};

if (seo) {
  serviceSchema.aggregateRating = {
    "@type": "AggregateRating",
    "ratingValue": seo.aggregateRating.ratingValue,
    "reviewCount": seo.aggregateRating.reviewCount,
    "bestRating": "5",
    "worstRating": "1"
  };
  if (seo.serviceAreas && seo.serviceAreas.length > 0) {
    serviceSchema.areaServed = [
      { "@type": "City", "name": "Malatya" },
      ...seo.serviceAreas.map(a => ({ "@type": "AdministrativeArea", "name": a }))
    ];
  }
}

const faqSchema = allFaqs && allFaqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${serviceUrl}#faq`,
  "mainEntity": allFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
} : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Anasayfa", "item": "https://malatyareklam.com/" },
    { "@type": "ListItem", "position": 2, "name": "Hizmetler", "item": "https://malatyareklam.com/hizmetler/" },
    { "@type": "ListItem", "position": 3, "name": service.title, "item": serviceUrl }
  ]
};

const pageSchemas: any[] = [serviceSchema, breadcrumbSchema];
if (faqSchema) pageSchemas.push(faqSchema);

const waMessage = encodeURIComponent(`Merhaba, ${service.title} hizmeti hakkında bilgi almak istiyorum.`);

const pageTitle = seo ? seo.metaTitle : `${service.title} Malatya | Malatya Reklam`;
const pageDescription = seo ? seo.metaDescription : service.shortDesc;
const pageH1 = seo ? seo.h1 : service.title;
const pageKeywords = seo ? [...service.keywords, ...seo.relatedKeywords].join(", ") : service.keywords.join(", ");
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonical={serviceUrl}
  jsonLd={pageSchemas}
>
  <section class="relative bg-gradient-to-br from-apricot-50 via-white to-orange-50 pt-12 pb-20 overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-apricot-200/30 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="container mx-auto px-4 lg:px-8 relative">
      <nav class="flex items-center gap-2 text-sm text-neutral-500 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-apricot-600 transition-colors">Anasayfa</a>
        <span>/</span>
        <a href="/hizmetler" class="hover:text-apricot-600 transition-colors">Hizmetler</a>
        <span>/</span>
        <span class="text-neutral-900 font-medium">{service.title}</span>
      </nav>
      <div class="max-w-4xl">
        <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">{categoryLabels[service.category]}</span>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 mb-6 leading-tight">{pageH1}</h1>
        <p class="text-xl text-neutral-600 leading-relaxed mb-8">{service.shortDesc}</p>
        {seo && <div class="text-neutral-700 leading-relaxed mb-8" set:html={seo.introHtml} />}
        <div class="flex flex-wrap gap-4">
          <a href="/iletisim" class="inline-flex items-center gap-2 px-6 py-3 bg-apricot-500 hover:bg-apricot-600 text-white font-semibold rounded-xl shadow-lg shadow-apricot-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all">
            Ücretsiz Teklif Al
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a
            href={`https://wa.me/905446732202?text=${waMessage}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-neutral-50 text-neutral-900 font-semibold rounded-xl border border-neutral-200 transition-all"
          >WhatsApp ile İletişim</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-12">
          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-4">Hizmet Detayları</h2>
            <p class="text-neutral-700 leading-relaxed text-lg">{service.longDesc}</p>
          </div>
          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Bu Hizmette Neler Var?</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {service.benefits.map(benefit => (
                <div class="flex items-start gap-3 p-5 bg-neutral-50 rounded-xl border border-neutral-100 hover:border-apricot-200 hover:bg-apricot-50 transition-colors">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-apricot-500 flex items-center justify-center text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <p class="text-neutral-800 font-medium pt-0.5">{benefit}</p>
                </div>
              ))}
            </div>
          </div>

          {seo && (
            <article class="prose prose-neutral max-w-none prose-headings:font-display prose-headings:text-neutral-900 prose-h2:text-3xl prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4 prose-h3:text-xl prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3 prose-p:text-neutral-700 prose-p:leading-relaxed prose-li:text-neutral-700 prose-a:text-apricot-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-neutral-900" set:html={seo.longContent} />
          )}

          {seo && seo.processSteps.length > 0 && (
            <div>
              <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Çalışma Sürecimiz</h2>
              <ol class="space-y-4">
                {seo.processSteps.map(step => (
                  <li class="flex gap-4 p-5 bg-white border border-neutral-200 rounded-xl">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-apricot-500 text-white flex items-center justify-center font-display text-xl font-bold">{step.step}</div>
                    <div>
                      <h3 class="font-display text-lg font-bold text-neutral-900 mb-1">{step.title}</h3>
                      <p class="text-neutral-700 leading-relaxed text-sm">{step.description}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          )}

          {seo && seo.pricingFactors.length > 0 && (
            <div>
              <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Fiyatı Belirleyen Faktörler</h2>
              <div class="space-y-3">
                {seo.pricingFactors.map(pf => (
                  <div class="p-5 bg-neutral-50 rounded-xl border border-neutral-100">
                    <h3 class="font-semibold text-neutral-900 mb-1">{pf.factor}</h3>
                    <p class="text-neutral-700 text-sm leading-relaxed">{pf.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {seo && seo.serviceAreas.length > 0 && (
            <div>
              <h2 class="font-display text-3xl font-bold text-neutral-900 mb-4">Hizmet Verdiğimiz Bölgeler</h2>
              <p class="text-neutral-600 mb-5">Malatya merkez ve tüm ilçelere {service.title.toLowerCase()} hizmeti sunuyoruz:</p>
              <div class="flex flex-wrap gap-2">
                {seo.serviceAreas.map(area => (
                  <span class="px-4 py-2 bg-white border border-neutral-200 rounded-full text-sm font-medium text-neutral-700 hover:border-apricot-300 hover:text-apricot-600 transition-colors">{area}</span>
                ))}
              </div>
            </div>
          )}

          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Sıkça Sorulan Sorular</h2>
            <div class="space-y-3">
              {allFaqs.map(faq => (
                <details class="group bg-white border border-neutral-200 rounded-xl overflow-hidden">
                  <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-neutral-50 transition-colors">
                    <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
                    <svg class="w-5 h-5 text-apricot-500 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-5 pb-5 text-neutral-700 leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>
        <aside class="lg:sticky lg:top-28 lg:h-fit space-y-6">
          <div class="p-6 bg-gradient-to-br from-apricot-500 to-apricot-600 text-white rounded-2xl shadow-xl">
            <h3 class="font-display text-2xl font-bold mb-3">Hemen Başlayalım</h3>
            <p class="text-apricot-50 mb-5 text-sm leading-relaxed">{service.title} hizmeti için ücretsiz keşif görüşmesi planlayın.</p>
            <a href="/iletisim" class="block w-full text-center px-5 py-3 bg-white text-apricot-600 font-semibold rounded-xl hover:bg-apricot-50 transition-colors">İletişime Geç</a>
          </div>

          {seo && seo.aggregateRating && (
            <div class="p-6 bg-white border border-neutral-200 rounded-2xl">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl font-display font-bold text-neutral-900">{seo.aggregateRating.ratingValue}</span>
                <span class="text-sm text-neutral-500">/ 5.0</span>
              </div>
              <div class="flex gap-0.5 text-apricot-500 mb-1">
                {[1,2,3,4,5].map(() => (<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>))}
              </div>
              <p class="text-xs text-neutral-500">{seo.aggregateRating.reviewCount}+ müşteri değerlendirmesi</p>
            </div>
          )}

          {seo && seo.internalLinks.length > 0 && (
            <div class="p-6 bg-white border border-neutral-200 rounded-2xl">
              <h3 class="font-display text-lg font-bold text-neutral-900 mb-4">Konuyla İlgili</h3>
              <ul class="space-y-2">
                {seo.internalLinks.map(link => (
                  <li><a href={link.href} class="text-sm text-apricot-600 hover:text-apricot-700 hover:underline">{link.text}</a></li>
                ))}
              </ul>
            </div>
          )}

          <div class="p-6 bg-white border border-neutral-200 rounded-2xl">
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-4">İlgili Hizmetler</h3>
            <ul class="space-y-2">
              {relatedServices.map(rs => (
                <li>
                  <a href={`/hizmetler/${rs.slug}`} class="flex items-center justify-between p-3 rounded-lg hover:bg-apricot-50 transition-colors group">
                    <span class="text-sm font-medium text-neutral-700 group-hover:text-apricot-600">{rs.title}</span>
                    <svg class="w-4 h-4 text-neutral-400 group-hover:text-apricot-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
