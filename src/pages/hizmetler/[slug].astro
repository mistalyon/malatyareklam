---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, categoryLabels } from '../../data/services';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const relatedServices = services.filter(s => s.category === service.category && s.slug !== service.slug).slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.shortDesc,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Malatya Reklam",
    "url": "https://malatyareklam.com"
  },
  "areaServed": { "@type": "City", "name": "Malatya" },
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": service.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  }
};
---

<BaseLayout title={`${service.title} | Malatya Reklam`} description={service.shortDesc} jsonLd={jsonLd}>
  <section class="relative bg-gradient-to-br from-apricot-50 via-white to-orange-50 pt-12 pb-20 overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-apricot-200/30 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="container mx-auto px-4 lg:px-8 relative">
      <nav class="flex items-center gap-2 text-sm text-neutral-500 mb-6">
        <a href="/" class="hover:text-apricot-600 transition-colors">Anasayfa</a>
        <span>/</span>
        <a href="/hizmetler" class="hover:text-apricot-600 transition-colors">Hizmetler</a>
        <span>/</span>
        <span class="text-neutral-900 font-medium">{service.title}</span>
      </nav>
      <div class="max-w-4xl">
        <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">{categoryLabels[service.category]}</span>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 mb-6 leading-tight">{service.title}</h1>
        <p class="text-xl text-neutral-600 leading-relaxed mb-8">{service.shortDesc}</p>
        <div class="flex flex-wrap gap-4">
          <a href="/iletisim" class="inline-flex items-center gap-2 px-6 py-3 bg-apricot-500 hover:bg-apricot-600 text-white font-semibold rounded-xl shadow-lg shadow-apricot-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all">
            Ücretsiz Teklif Al
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="https://wa.me/905551234567" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-neutral-50 text-neutral-900 font-semibold rounded-xl border border-neutral-200 transition-all">WhatsApp ile İletişim</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-12">
          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-4">Hizmet Detayları</h2>
            <p class="text-neutral-700 leading-relaxed text-lg">{service.longDesc}</p>
          </div>
          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Bu Hizmette Neler Var?</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {service.benefits.map(benefit => (
                <div class="flex items-start gap-3 p-5 bg-neutral-50 rounded-xl border border-neutral-100 hover:border-apricot-200 hover:bg-apricot-50 transition-colors">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-apricot-500 flex items-center justify-center text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <p class="text-neutral-800 font-medium pt-0.5">{benefit}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Sıkça Sorulan Sorular</h2>
            <div class="space-y-3">
              {service.faqs.map(faq => (
                <details class="group bg-white border border-neutral-200 rounded-xl overflow-hidden">
                  <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-neutral-50 transition-colors">
                    <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
                    <svg class="w-5 h-5 text-apricot-500 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-5 pb-5 text-neutral-700 leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>
        <aside class="lg:sticky lg:top-28 lg:h-fit space-y-6">
          <div class="p-6 bg-gradient-to-br from-apricot-500 to-apricot-600 text-white rounded-2xl shadow-xl">
            <h3 class="font-display text-2xl font-bold mb-3">Hemen Başlayalım</h3>
            <p class="text-apricot-50 mb-5 text-sm leading-relaxed">{service.title} hizmeti için ücretsiz keşif görüşmesi planlayın.</p>
            <a href="/iletisim" class="block w-full text-center px-5 py-3 bg-white text-apricot-600 font-semibold rounded-xl hover:bg-apricot-50 transition-colors">İletişime Geç</a>
          </div>
          <div class="p-6 bg-white border border-neutral-200 rounded-2xl">
            <h3 class="font-display text-lg font-bold text-neutral-900 mb-4">İlgili Hizmetler</h3>
            <ul class="space-y-2">
              {relatedServices.map(rs => (
                <li>
                  <a href={`/hizmetler/${rs.slug}`} class="flex items-center justify-between p-3 rounded-lg hover:bg-apricot-50 transition-colors group">
                    <span class="text-sm font-medium text-neutral-700 group-hover:text-apricot-600">{rs.title}</span>
                    <svg class="w-4 h-4 text-neutral-400 group-hover:text-apricot-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
