---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { slug: 'web-tasarim-fiyat-hesaplama', icon: '💻', title: 'Web Tasarım Fiyat Hesaplama', description: 'Site tipi, sayfa sayısı ve özellikleri seçin, anlık fiyat tahmini alın.', cta: 'Hesapla' },
  { slug: 'tabela-fiyat-hesaplama', icon: '🪧', title: 'Tabela Fiyat Hesaplama', description: 'Tabela tipi, boyut ve aydınlatma seçeneklerine göre maliyet hesaplayıcı.', cta: 'Hesapla' },
  { slug: 'seo-roi-hesaplama', icon: '📈', title: 'SEO ROI Hesaplama', description: 'SEO yatırımınızın 12 aylık geri dönüşünü ve başabaş ayını hesaplayın.', cta: 'Hesapla' },
  { slug: 'google-ads-butce-hesaplama', icon: '🎯', title: 'Google Ads Bütçe Hesaplama', description: 'Sektör CPC verileriyle aylık tıklama, dönüşüm ve müşteri tahmini.', cta: 'Hesapla' },
  { slug: 'matbaa-baski-fiyat-hesaplama', icon: '🖨️', title: 'Matbaa Baskı Fiyat Hesaplama', description: 'Kartvizit, broşür, katalog ve afiş baskı maliyeti anında hesaplayıcı.', cta: 'Hesapla' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Ücretsiz Pazarlama Araçları | Malatya Reklam',
  description: 'Web tasarım fiyat, tabela fiyat, SEO ROI, Google Ads bütçe ve matbaa hesaplayıcıları. Reklam ve dijital pazarlama yatırımlarınızı planlayın.',
};
---

<BaseLayout
  title="Ücretsiz Pazarlama Araçları | Web Tasarım, Tabela, SEO ve Google Ads Hesaplayıcıları"
  description="Web tasarım fiyat hesaplama, tabela maliyet, SEO ROI, Google Ads bütçe ve matbaa baskı araçları. Pazarlama yatırımlarınızı 2026 verileriyle planlayın."
  keywords="pazarlama hesaplayıcı, fiyat hesaplama araçları, seo roi, web tasarım fiyat, tabela hesaplayıcı, malatya reklam araçları"
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl text-center">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">Ücretsiz Araçlar</span>
      <h1 class="font-display text-4xl md:text-6xl font-bold text-neutral-900 mb-6 leading-tight">Pazarlama ve Bütçe Hesaplama Araçları</h1>
      <p class="text-xl text-neutral-600 leading-relaxed">Web tasarımdan tabela maliyetine, SEO ROI'dan Google Ads bütçesine kadar — yatırımlarınızı 2026 Malatya pazarı verileriyle ücretsiz hesaplayın.</p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {tools.map(t => (
          <a href={`/araclar/${t.slug}`} class="group bg-white rounded-2xl border border-neutral-200 p-6 hover:border-apricot-300 hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-apricot-100 to-apricot-200 flex items-center justify-center text-3xl mb-4">{t.icon}</div>
            <h2 class="font-display text-xl font-bold text-neutral-900 mb-2 group-hover:text-apricot-600 transition-colors">{t.title}</h2>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{t.description}</p>
            <div class="flex items-center gap-2 text-sm font-semibold text-apricot-600">
              {t.cta}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-16 p-8 bg-neutral-50 rounded-2xl max-w-3xl mx-auto">
        <h3 class="font-display text-2xl font-bold text-neutral-900 mb-3">Aradığınız Araç Burada Yok mu?</h3>
        <p class="text-neutral-600 mb-6">İhtiyacınız olan hesaplayıcı veya öneriniz varsa bize yazın; bir sonraki güncellemeye dahil edelim.</p>
        <a href="/iletisim" class="inline-flex items-center gap-2 px-6 py-3 bg-apricot-500 hover:bg-apricot-600 text-white font-bold rounded-xl transition-colors">İletişim Formu →</a>
      </div>
    </div>
  </section>
</BaseLayout>
