---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Ücretsiz Reklam ve Pazarlama Araçları | Malatya Reklam";
const description = "Web tasarım, tabela, SEO, Google Ads, matbaa ve reklam bütçesi hesaplama araçları. Tamamı ücretsiz, Türkiye 2026 fiyatlarıyla güncel.";

const tools = [
  { slug: "reklam-butce-hesaplama", title: "Reklam Bütçesi Hesaplayıcı", desc: "Instagram + Google + YouTube + Facebook için aylık bütçe önerisi.", emoji: "💰" },
  { slug: "google-ads-butce-hesaplama", title: "Google Ads Bütçe Hesaplama", desc: "Sektör + hedeflere göre Google Ads aylık bütçe + tahmini sonuç.", emoji: "🔎" },
  { slug: "seo-roi-hesaplama", title: "SEO ROI Hesaplama", desc: "SEO yatırımının ne kadar geri dönüş sağlayacağını hesapla.", emoji: "📈" },
  { slug: "web-tasarim-fiyat-hesaplama", title: "Web Tasarım Fiyat Hesaplama", desc: "Sayfa sayısı, özellikler, e-ticaret modülüne göre web sitesi maliyeti.", emoji: "💻" },
  { slug: "tabela-fiyat-hesaplama", title: "Tabela Fiyat Hesaplama", desc: "Metrekare, malzeme ve aydınlatmaya göre tabela maliyeti.", emoji: "🪧" },
  { slug: "matbaa-baski-fiyat-hesaplama", title: "Matbaa Baskı Fiyat Hesaplama", desc: "Kartvizit, broşür, afiş, katalog için anlık baskı fiyatı.", emoji: "🖨️" },
];
---

<BaseLayout title={title} description={description}>
  <section class="bg-gradient-to-br from-apricot-50 to-white py-12 lg:py-16">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 bg-apricot-100 text-apricot-700 text-sm font-semibold rounded-full mb-4">Ücretsiz Araçlar</span>
        <h1 class="text-3xl lg:text-5xl font-bold text-neutral-900 mb-4">Reklam ve Pazarlama Araçları</h1>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
          Bütçe planlamadan fiyat hesaplamaya, sıfırdan profesyonel kuruluma kadar — tüm araçlar ücretsiz ve Türkiye 2026 verileriyle güncel.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map(t => (
          <a href={`/araclar/${t.slug}/`} class="group block bg-white p-6 rounded-2xl shadow-sm hover:shadow-lg border border-neutral-200 hover:border-apricot-400 transition">
            <div class="text-4xl mb-3">{t.emoji}</div>
            <h2 class="text-xl font-bold text-neutral-900 group-hover:text-apricot-600 mb-2">{t.title}</h2>
            <p class="text-sm text-neutral-600">{t.desc}</p>
            <span class="inline-block mt-4 text-sm font-semibold text-apricot-600">Hesaplamaya Başla →</span>
          </a>
        ))}
      </div>

      <div class="mt-16 bg-white rounded-2xl p-8 shadow-sm border border-neutral-200 text-center">
        <h2 class="text-2xl font-bold text-neutral-900 mb-3">Profesyonel Destek Lazım mı?</h2>
        <p class="text-neutral-600 mb-5">Araçlar yön gösterir; uygulama için Malatya Reklam ekibi yanında.</p>
        <a href="https://wa.me/905446732202?text=Merhaba%2C%20strateji%20g%C3%B6r%C3%BC%C5%9Fmesi%20i%C3%A7in%20ulasiyorum" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-lg">
          WhatsApp'tan Görüşelim
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
