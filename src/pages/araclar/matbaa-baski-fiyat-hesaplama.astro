---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Matbaa Baskı Fiyat Hesaplama Aracı',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'TRY' },
  description: 'Kartvizit, broşür, katalog, afiş, poster, etiket gibi matbaa baskı işlerinin maliyetini anında hesaplayın.',
};
---

<BaseLayout
  title="Matbaa Baskı Fiyat Hesaplama Aracı 2026 — Kartvizit, Broşür, Afiş Maliyet | Malatya Reklam"
  description="Kartvizit, broşür, katalog, afiş ve etiket baskınızın maliyetini anında hesaplayın. Adet, kâğıt, renk, kaplama seçeneklerine göre 2026 Malatya pazarı verileri."
  keywords="matbaa fiyat hesaplama, kartvizit fiyatı, broşür baskı maliyeti, afiş poster fiyat, katalog baskı, malatya matbaa, dijital baskı fiyat 2026"
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl text-center">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">Ücretsiz Araç</span>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight mb-6">Matbaa Baskı Fiyat Hesaplayıcı</h1>
      <p class="text-xl text-neutral-600 leading-relaxed">Kartvizit, broşür, katalog, afiş veya etiket baskınızın maliyetini anında öğrenin. Ürün tipi, adet, kâğıt ve kaplama seçeneklerine göre 2026 fiyat tahmini.</p>
    </div>
  </section>

  <section class="py-12 lg:py-16">
    <div class="container mx-auto px-4 lg:px-8 max-w-3xl">
      <form id="m-form" class="bg-white rounded-3xl shadow-2xl border border-neutral-100 p-8 lg:p-10 space-y-8">
        <div>
          <label class="block text-sm font-bold text-neutral-900 mb-3">1. Ürün Tipi</label>
          <select name="product" class="w-full px-4 py-3 border-2 border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none">
            <option value="kartvizit">Kartvizit (8.5x5.5 cm)</option>
            <option value="brosur">Broşür A5/A4</option>
            <option value="katalog">Katalog (16-24 sayfa)</option>
            <option value="afis">Afiş A2/A1</option>
            <option value="poster">Poster B1 (70x100)</option>
            <option value="etiket">Etiket / Sticker</option>
            <option value="antetli">Antetli Kağıt A4</option>
            <option value="zarf">Zarf Çeşitleri</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-neutral-900 mb-2">2. Adet: <span id="q-val" class="text-apricot-600">1.000</span></label>
          <input type="range" name="qty" min="50" max="10000" value="1000" step="50" class="w-full accent-apricot-500" />
          <div class="flex justify-between text-xs text-neutral-500 mt-1"><span>50</span><span>5.000</span><span>10.000+</span></div>
        </div>
        <div>
          <label class="block text-sm font-bold text-neutral-900 mb-3">3. Kâğıt Cinsi</label>
          <select name="paper" class="w-full px-4 py-3 border-2 border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none">
            <option value="kromo">Kromo (Standart, parlak)</option>
            <option value="mat" selected>Mat Kuşe</option>
            <option value="bristol">Bristol (Kalın, prim. kartvizit)</option>
            <option value="koton">Koton (Doğal, lüks)</option>
            <option value="metalik">Metalik (Premium, hediye)</option>
            <option value="geri-don">Geri Dönüşümlü</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-neutral-900 mb-3">4. Renk Seçimi</label>
          <div class="grid grid-cols-3 gap-3">
            <label class="cursor-pointer"><input type="radio" name="color" value="bw" class="peer sr-only" /><div class="p-3 border-2 border-neutral-200 rounded-xl peer-checked:border-apricot-500 peer-checked:bg-apricot-50 text-center text-sm font-bold">Siyah-Beyaz</div></label>
            <label class="cursor-pointer"><input type="radio" name="color" value="cmyk" class="peer sr-only" checked /><div class="p-3 border-2 border-neutral-200 rounded-xl peer-checked:border-apricot-500 peer-checked:bg-apricot-50 text-center text-sm font-bold">Renkli (CMYK)</div></label>
            <label class="cursor-pointer"><input type="radio" name="color" value="pms" class="peer sr-only" /><div class="p-3 border-2 border-neutral-200 rounded-xl peer-checked:border-apricot-500 peer-checked:bg-apricot-50 text-center text-sm font-bold">Pantone (PMS)</div></label>
          </div>
        </div>
        <div>
          <label class="block text-sm font-bold text-neutral-900 mb-3">5. Ek Hizmetler</label>
          <div class="grid sm:grid-cols-2 gap-2">
            <label class="flex items-center gap-2 p-3 border-2 border-neutral-200 rounded-xl hover:bg-neutral-50 cursor-pointer"><input type="checkbox" name="ext" value="lakli" class="accent-apricot-500" /> Selefon / Lak Kaplama</label>
            <label class="flex items-center gap-2 p-3 border-2 border-neutral-200 rounded-xl hover:bg-neutral-50 cursor-pointer"><input type="checkbox" name="ext" value="kabartma" class="accent-apricot-500" /> Yaldız / Kabartma</label>
            <label class="flex items-center gap-2 p-3 border-2 border-neutral-200 rounded-xl hover:bg-neutral-50 cursor-pointer"><input type="checkbox" name="ext" value="design" class="accent-apricot-500" /> Tasarım Hizmeti</label>
            <label class="flex items-center gap-2 p-3 border-2 border-neutral-200 rounded-xl hover:bg-neutral-50 cursor-pointer"><input type="checkbox" name="ext" value="ekspres" class="accent-apricot-500" /> 24 Saat Ekspres Teslim</label>
          </div>
        </div>
        <div class="bg-gradient-to-br from-apricot-50 to-orange-50 border-2 border-apricot-200 rounded-2xl p-6 lg:p-8 text-center">
          <div class="text-sm font-bold uppercase tracking-wider text-apricot-700 mb-2">Tahmini Toplam Maliyet</div>
          <div class="font-display text-4xl md:text-5xl font-bold text-neutral-900"><span id="m-min">0</span> ₺ <span class="text-neutral-400">-</span> <span id="m-max">0</span> ₺</div>
          <div class="text-xs text-neutral-500 mt-3">Adet başı: <span id="m-per" class="font-bold">0</span> ₺ · Tahmini teslim: <span id="m-time" class="font-bold">3-5 iş günü</span></div>
        </div>
        <a id="m-cta" href="https://wa.me/905555555555" target="_blank" rel="noopener" class="block w-full text-center px-6 py-4 bg-apricot-500 hover:bg-apricot-600 text-white text-lg font-bold rounded-xl transition shadow-lg shadow-apricot-500/30">WhatsApp'tan Detaylı Teklif Al →</a>
        <p class="text-xs text-neutral-500 text-center">Tahminler 2026 Malatya matbaa pazarına dayalı ortalamalardır. Kesin fiyat için tasarım dosyanızla birlikte teklif isteyin.</p>
      </form>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-neutral-50">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-8 text-center">Matbaa Baskı Fiyatları Nasıl Hesaplanır?</h2>
      <div class="prose prose-lg max-w-none">
        <p>Matbaa baskı maliyetinde 5 ana değişken vardır: <strong>ürün tipi</strong>, <strong>adet</strong>, <strong>kâğıt cinsi</strong>, <strong>renk modu</strong> ve <strong>kaplama/ek hizmetler</strong>. Bunların kombinasyonu nihai fiyatı belirler. 1000 adet kartvizit ile 100 adet katalog farklı dünyalardır.</p>
        <h3>Adet Etkisi (Ekonomi Eşiği)</h3>
        <p>Matbaada en önemli kural: <strong>kalıp maliyeti</strong>. 100 adet baskı ile 1000 adet baskı arasındaki fiyat farkı 5 kat değil, 1.5-2 kattır; çünkü kalıp masrafı sabittir. Genel kural: ihtiyacınızın 2 katı baskı yaptırın, birim maliyet yarıya iner.</p>
        <h3>Kâğıt Seçimi Stratejisi</h3>
        <p>Mat kuşe çoğu işletme için ideal: parmak izi tutmaz, modern görünür, fiyat orta. Bristol kartvizit için lüks algı yaratır ama 2 kat pahalıdır. Geri dönüşümlü kâğıt sürdürülebilirlik vurgusu için tercih edilir; markanıza pozitif değer katar.</p>
        <h3>Selefon ve Yaldız: Ne Zaman Mantıklı?</h3>
        <p>Selefon kaplama (parlak veya mat) parmak izi tutmaz ve kartvizitin ömrünü 3 katına çıkarır; +%20-30 maliyet için faydası net. Yaldız ve kabartma ise lüks segmentte (kuyumcu, ajans, danışman) marka algısını yükseltir; +%50-100 maliyet getirir.</p>
        <h3>Renk Seçenekleri Arasındaki Fark</h3>
        <p>CMYK 4 renkli ofset standarttır. Pantone (PMS) ise marka kimlik renklerinde tutarlılık için kullanılır; logonuzun her baskıda aynı tonda görünmesini sağlar. Pantone +%20-40 maliyet getirir ama kurumsal markaların kullandığı standarttır.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const f = document.getElementById("m-form");
    const qV = document.getElementById("q-val");
    const mMin = document.getElementById("m-min");
    const mMax = document.getElementById("m-max");
    const mPer = document.getElementById("m-per");
    const mTime = document.getElementById("m-time");
    const cta = document.getElementById("m-cta");
    const fmt = (n) => Math.round(n).toLocaleString("tr-TR");
    // Birim fiyat ranges (TL/adet)
    const prodBase = { kartvizit:[0.5,2.5], brosur:[2,8], katalog:[15,55], afis:[12,40], poster:[20,65], etiket:[0.3,1.5], antetli:[1.2,4], zarf:[1,3.5] };
    const paperMul = { kromo:0.85, mat:1.0, bristol:1.4, koton:1.6, metalik:2.0, "geri-don":1.15 };
    const colorMul = { bw:0.6, cmyk:1.0, pms:1.3 };
    const extPrice = { lakli:0.25, kabartma:0.7, design:300, ekspres:200 };
    const setupCost = 250; // kalıp/setup ücreti
    function calc() {
      const d = new FormData(f);
      const p = d.get("product");
      const q = parseInt(d.get("qty"));
      const paper = d.get("paper");
      const color = d.get("color");
      const exts = d.getAll("ext");
      const [bMin, bMax] = prodBase[p];
      const pm = paperMul[paper];
      const cm = colorMul[color];
      // Per unit ext (adet başı)
      let perUnitExt = 0;
      let flatExt = 0;
      exts.forEach(e => {
        if (e === "design" || e === "ekspres") flatExt += extPrice[e];
        else perUnitExt += extPrice[e];
      });
      const minU = bMin * pm * cm + perUnitExt;
      const maxU = bMax * pm * cm + perUnitExt;
      const min = minU * q + setupCost + flatExt;
      const max = maxU * q + setupCost * 1.5 + flatExt;
      const time = exts.includes("ekspres") ? "1 iş günü" : (q > 5000 ? "5-7 iş günü" : "3-5 iş günü");
      qV.textContent = fmt(q);
      mMin.textContent = fmt(min);
      mMax.textContent = fmt(max);
      mPer.textContent = ((min/q).toFixed(2));
      mTime.textContent = time;
      const msg = "Merhaba, matbaa hesaplayicisindan geliyorum. Urun: " + p + ", " + q + " adet, kagit: " + paper + ", renk: " + color + ". Tahmini butce: " + fmt(min) + "-" + fmt(max) + " TL. Detayli teklif almak istiyorum.";
      cta.href = "https://wa.me/905555555555?text=" + encodeURIComponent(msg);
    }
    f.addEventListener("input", calc);
    calc();
  </script>
</BaseLayout>
