---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (d: Date) =>
  d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: 'https://malatyareklam.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Malatya Reklam',
    logo: {
      '@type': 'ImageObject',
      url: 'https://malatyareklam.com/logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://malatyareklam.com/blog/${post.slug}`,
  },
  articleSection: post.data.category,
};
---

<BaseLayout
  title={post.data.seoTitle || `${post.data.title} | Malatya Reklam`}
  description={post.data.seoDescription || post.data.excerpt}
  keywords={post.data.keywords}
  jsonLd={articleJsonLd}
>
  <article class="bg-gradient-to-br from-apricot-50 via-white to-orange-50">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl py-16 lg:py-20">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-apricot-600 hover:text-apricot-700 mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Tüm yazılar
      </a>
      <div class="flex items-center gap-3 text-xs text-neutral-500 mb-4">
        <span class="px-2 py-1 bg-apricot-100 text-apricot-700 font-bold rounded">{post.data.category}</span>
        <span>{formatDate(post.data.date)}</span>
        <span>·</span>
        <span>{post.data.readTime} okuma</span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight mb-6">{post.data.title}</h1>
      <p class="text-xl text-neutral-600 leading-relaxed mb-10">{post.data.excerpt}</p>
    </div>
  </article>

  <section class="py-12 lg:py-16">
    <div class="container mx-auto px-4 lg:px-8 max-w-3xl">
      <div class="prose prose-lg prose-neutral max-w-none prose-headings:font-display prose-headings:text-neutral-900 prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3 prose-p:text-neutral-700 prose-p:leading-relaxed prose-a:text-apricot-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-neutral-900 prose-li:text-neutral-700">
        <Content />
      </div>

      <div class="mt-16 p-8 bg-gradient-to-br from-apricot-50 to-orange-50 border border-apricot-200 rounded-2xl text-center">
        <h3 class="font-display text-2xl font-bold text-neutral-900 mb-3">Projeniz İçin Birlikte Çalışalım</h3>
        <p class="text-neutral-600 mb-6">Malatya'da reklam, SEO, web tasarım ve dijital pazarlama çözümleri.</p>
        <a href="/iletisim" class="inline-flex items-center gap-2 px-6 py-3 bg-apricot-500 hover:bg-apricot-600 text-white font-bold rounded-xl transition-colors">
          İletişime Geç
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
