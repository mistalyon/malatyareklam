---
import BaseLayout from '../layouts/BaseLayout.astro';

const channels = [
  { icon: '📞', label: 'Telefon', value: '+90 555 123 45 67', href: 'tel:+905551234567' },
  { icon: '✉️', label: 'E-Posta', value: 'info@malatyareklam.com', href: 'mailto:info@malatyareklam.com' },
  { icon: '💬', label: 'WhatsApp', value: 'WhatsApp ile yazın', href: 'https://wa.me/905551234567' },
  { icon: '📍', label: 'Adres', value: 'İnönü Cad. No:123, Battalgazi/Malatya', href: '#' }
];
---

<BaseLayout title="İletişim | Malatya Reklam" description="Malatya Reklam ile iletişime geçin. Ücretsiz teklif almak için formu doldurun veya WhatsApp'tan yazın.">
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl text-center">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">İletişim</span>
      <h1 class="font-display text-4xl md:text-6xl font-bold text-neutral-900 mb-6 leading-tight">Bize Ulaşın</h1>
      <p class="text-xl text-neutral-600 leading-relaxed">Projeniz için ücretsiz keşif görüşmesi planlayalım. 24 saat içinde dönüş yapıyoruz.</p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">İletişim Kanalları</h2>
          <div class="space-y-4">
            {channels.map(ch => (
              <a href={ch.href} class="flex items-center gap-4 p-5 bg-white border border-neutral-200 rounded-2xl hover:border-apricot-300 hover:shadow-lg transition-all group">
                <div class="text-3xl">{ch.icon}</div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-1">{ch.label}</div>
                  <div class="font-semibold text-neutral-900 group-hover:text-apricot-600 transition-colors">{ch.value}</div>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-8 p-6 bg-neutral-900 text-white rounded-2xl">
            <h3 class="font-display text-xl font-bold mb-2">Çalışma Saatleri</h3>
            <p class="text-sm text-neutral-300 mb-4">Pazartesi - Cuma: 09:00 - 18:00<br/>Cumartesi: 10:00 - 14:00</p>
            <p class="text-xs text-neutral-400">Acil durumlar için 7/24 WhatsApp desteği aktiftir.</p>
          </div>
        </div>

        <div>
          <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Teklif Formu</h2>
          <form class="space-y-4 p-6 bg-white border border-neutral-200 rounded-2xl">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-neutral-700 mb-2">Ad Soyad *</label>
                <input type="text" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="Adınız Soyadınız" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-neutral-700 mb-2">Telefon *</label>
                <input type="tel" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="0555 555 55 55" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-2">E-Posta *</label>
              <input type="email" required class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="ornek@firma.com" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-2">Hizmet</label>
              <select class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all">
                <option>Reklam (Açıkhava, Tabela, Matbaa)</option>
                <option>Dijital Pazarlama (SEO, Sosyal Medya, Ads)</option>
                <option>Web Tasarım & E-Ticaret</option>
                <option>Yazılım Geliştirme</option>
                <option>AI & GEO Çözümleri</option>
                <option>Diğer</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-neutral-700 mb-2">Mesajınız *</label>
              <textarea required rows="5" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all resize-none" placeholder="Projeniz hakkında detay verin..."></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" required id="kvkk" class="mt-1 w-4 h-4 text-apricot-500" />
              <label for="kvkk" class="text-sm text-neutral-600">
                <a href="/kvkk" class="text-apricot-600 underline">KVKK Aydınlatma Metni</a>'ni okudum ve onaylıyorum.
              </label>
            </div>
            <button type="submit" class="w-full px-6 py-4 bg-apricot-500 hover:bg-apricot-600 text-white font-bold rounded-xl shadow-lg shadow-apricot-500/25 hover:shadow-xl transition-all">Teklif Talep Et</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
