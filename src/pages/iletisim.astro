---
import BaseLayout from '../layouts/BaseLayout.astro';

const channels = [
  { icon: '📞', label: 'Telefon', value: '+90 544 673 22 02', href: 'tel:+905446732202' },
  { icon: '✉️', label: 'E-Posta', value: 'info@malatyareklam.com', href: 'mailto:info@malatyareklam.com' },
  { icon: '💬', label: 'WhatsApp', value: 'WhatsApp ile yazın', href: 'https://wa.me/905446732202' },
  { icon: '📍', label: 'Adres', value: 'İnönü Cad. No:123, Battalgazi/Malatya', href: '#' }
];
---

<BaseLayout title="İletişim | Malatya Reklam" description="Malatya Reklam ile iletişime geçin. Ücretsiz teklif almak için formu doldurun veya WhatsApp'tan yazın.">
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl text-center">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">İletişim</span>
      <h1 class="font-display text-4xl md:text-6xl font-bold text-neutral-900 mb-6 leading-tight">Bize Ulaşın</h1>
      <p class="text-xl text-neutral-600 leading-relaxed">Projeniz için ücretsiz keşif görüşmesi planlayalım. 24 saat içinde dönüş yapıyoruz.</p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">İletişim Kanalları</h2>
          <div class="space-y-4">
            {channels.map(ch => (
              <a href={ch.href} class="flex items-center gap-4 p-5 bg-white border border-neutral-200 rounded-2xl hover:border-apricot-300 hover:shadow-lg transition-all group">
                <div class="text-3xl">{ch.icon}</div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-1">{ch.label}</div>
                  <div class="font-semibold text-neutral-900 group-hover:text-apricot-600 transition-colors">{ch.value}</div>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-8 p-6 bg-neutral-900 text-white rounded-2xl">
            <h3 class="font-display text-xl font-bold mb-2">Çalışma Saatleri</h3>
            <p class="text-sm text-neutral-300 mb-4">Pazartesi - Cuma: 09:00 - 18:00<br/>Cumartesi: 10:00 - 14:00</p>
            <p class="text-xs text-neutral-400">Acil durumlar için 7/24 WhatsApp desteği aktiftir.</p>
          </div>
        </div>

        <div>
          <h2 class="font-display text-3xl font-bold text-neutral-900 mb-6">Teklif Formu</h2>
          <form id="contact-form" novalidate class="space-y-4 p-6 bg-white border border-neutral-200 rounded-2xl">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="contact-name" class="block text-sm font-semibold text-neutral-700 mb-2">Ad Soyad *</label>
                <input id="contact-name" name="name" type="text" required minlength="2" maxlength="200" autocomplete="name" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="Adınız Soyadınız" />
              </div>
              <div>
                <label for="contact-phone" class="block text-sm font-semibold text-neutral-700 mb-2">Telefon *</label>
                <input id="contact-phone" name="phone" type="tel" required minlength="7" maxlength="30" autocomplete="tel" inputmode="tel" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="0555 555 55 55" />
              </div>
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-semibold text-neutral-700 mb-2">E-Posta *</label>
              <input id="contact-email" name="email" type="email" required maxlength="200" autocomplete="email" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all" placeholder="ornek@firma.com" />
            </div>
            <div>
              <label for="contact-service" class="block text-sm font-semibold text-neutral-700 mb-2">Hizmet</label>
              <select id="contact-service" name="service" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all">
                <option value="Reklam">Reklam (Açıkhava, Tabela, Matbaa)</option>
                <option value="Dijital Pazarlama">Dijital Pazarlama (SEO, Sosyal Medya, Ads)</option>
                <option value="Web & E-Ticaret">Web Tasarım & E-Ticaret</option>
                <option value="Yazılım">Yazılım Geliştirme</option>
                <option value="AI & GEO">AI & GEO Çözümleri</option>
                <option value="Diğer">Diğer</option>
              </select>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-semibold text-neutral-700 mb-2">Mesajınız *</label>
              <textarea id="contact-message" name="message" required minlength="10" maxlength="4000" rows="5" class="w-full px-4 py-3 border border-neutral-200 rounded-xl focus:border-apricot-500 focus:outline-none focus:ring-2 focus:ring-apricot-200 transition-all resize-none" placeholder="Projeniz hakkında detay verin..."></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" required name="kvkk" id="kvkk" class="mt-1 w-4 h-4 text-apricot-500" />
              <label for="kvkk" class="text-sm text-neutral-600">
                <a href="/kvkk" class="text-apricot-600 underline">KVKK Aydınlatma Metni</a>'ni okudum ve onaylıyorum.
              </label>
            </div>
            <!-- Honeypot: visually hidden field. Real users do not fill this in. -->
            <div aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden">
              <label>Web siteniz<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
            </div>
            <button type="submit" id="contact-submit" class="w-full px-6 py-4 bg-apricot-500 hover:bg-apricot-600 disabled:opacity-60 disabled:cursor-not-allowed text-white font-bold rounded-xl shadow-lg shadow-apricot-500/25 hover:shadow-xl transition-all">Teklif Talep Et</button>
            <div id="contact-status" role="status" aria-live="polite" class="hidden text-sm rounded-xl px-4 py-3"></div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    if (!form) return;
    const submitBtn = document.getElementById('contact-submit');
    const status = document.getElementById('contact-status');

    function setStatus(message, kind) {
      if (!status) return;
      status.textContent = message;
      status.className = 'text-sm rounded-xl px-4 py-3 ' + (
        kind === 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' :
        kind === 'error'   ? 'bg-rose-50 text-rose-800 border border-rose-200' :
                             'bg-neutral-50 text-neutral-700 border border-neutral-200'
      );
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement)) return;

      const fd = new FormData(form);
      const payload = Object.fromEntries(fd.entries());
      payload.kvkk = form.querySelector('#kvkk') && form.querySelector('#kvkk').checked ? 'on' : '';

      submitBtn && submitBtn.setAttribute('disabled', 'true');
      setStatus('Gönderiliyor...', 'info');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          form.reset();
          setStatus('Teşekkürler! Mesajınızı aldık, 24 saat içinde size dönüş yapacağız.', 'success');
        } else if (res.status === 422) {
          const data = await res.json().catch(() => ({}));
          const fields = (data && data.fields) || {};
          const firstError = Object.values(fields)[0];
          setStatus(firstError ? String(firstError) : 'Lütfen formu kontrol edin.', 'error');
        } else if (res.status === 503) {
          setStatus('Şu anda formu alamıyoruz. Lütfen WhatsApp veya telefon ile iletinizi gönderin.', 'error');
        } else {
          setStatus('Beklenmeyen bir hata oluştu. Lütfen tekrar deneyin.', 'error');
        }
      } catch (err) {
        setStatus('Ağ hatası. İnternet bağlantınızı kontrol edip tekrar deneyin.', 'error');
      } finally {
        submitBtn && submitBtn.removeAttribute('disabled');
      }
    });
  })();
</script>
