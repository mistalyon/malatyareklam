---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  { icon: '🎯', title: 'Sonuç Odaklı', desc: 'Her kampanyada ölçülebilir hedefler ve şeffaf raporlama.' },
  { icon: '🤝', title: 'Müşteri Ortaklığı', desc: 'Müşterilerimizi ajans-müşteri değil, büyüme ortağı olarak görüyoruz.' },
  { icon: '🚀', title: 'Yenilikçilik', desc: 'AI, GEO ve yeni nesil teknolojilerle geleceğe hazır çözümler.' },
  { icon: '💎', title: 'Kalite', desc: 'Her detayda mükemmellik, her teslimat profesyonel standartlarda.' }
];

  { year: '2013', title: 'Kuruluş', desc: 'Malatya\'da küçük bir reklam ofisi olarak yola çıktık.' },
  { year: '2017', title: 'Dijital Dönüşüm', desc: 'SEO, sosyal medya ve web tasarım hizmetleri eklendi.' },
  { year: '2020', title: 'E-Ticaret', desc: 'Yerli işletmelerin online satışa geçişine destek olduk.' },
  { year: '2024', title: 'AI & GEO', desc: 'Yapay zeka destekli içerik ve GEO uzmanlığı.' }
];
---

<BaseLayout title="Hakkımızda | Malatya Reklam Ajansı - 2013'ten Beri" description="2013'ten beri Malatya'nın yenilikçi reklam ajansı. SEO, web tasarım, e-ticaret, yazılım ve dijital pazarlamada 12+ yıllık tecrübe. Ekibimizi tanıyın." keywords="malatya reklam ajansı, reklam ajansı hakkımızda, malatya ajans ekibi, malatya reklam tarihçesi, reklam ajansı misyonu, reklam ajansı vizyonu">
  <section class="bg-gradient-to-br from-apricot-50 via-white to-orange-50 py-16 lg:py-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
      <span class="inline-block px-3 py-1 bg-apricot-100 text-apricot-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">Hakkımızda</span>
      <h1 class="font-display text-4xl md:text-6xl font-bold text-neutral-900 mb-6 leading-tight">
        Malatya'nın <span class="text-apricot-500">Yeni Nesil</span> Reklam Ajansı
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed">
        2013'ten beri Malatya'da kurumsal markaların büyüme ortağıyız. Klasik reklam ile yapay zeka destekli yeni nesil pazarlamayı bir araya getiriyoruz.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-6">Misyonumuz</h2>
          <p class="text-lg text-neutral-700 leading-relaxed">
            Malatya'lı işletmelere küresel rekabet gücü kazandırmak. Yerel hassasiyetimizle global standartlarda çözümler üreterek, markaların hem fiziksel hem de dijital dünyada güçlü konumlanmasını sağlamak.
          </p>
        </div>
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-6">Vizyonumuz</h2>
          <p class="text-lg text-neutral-700 leading-relaxed">
            Türkiye'nin Anadolu'dan çıkmış en güçlü reklam ve dijital pazarlama markası olmak. Yapay zeka, GEO ve yeni nesil teknolojilerde sektör öncüsü olarak müşterilerimizi rakiplerinin önüne taşımak.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-neutral-50">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-4">Değerlerimiz</h2>
        <p class="text-lg text-neutral-600">Her projemizde bize yön veren temel ilkeler.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {values.map(v => (
          <div class="p-6 bg-white rounded-2xl border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
            <div class="text-4xl mb-4">{v.icon}</div>
            <h3 class="font-display text-xl font-bold text-neutral-900 mb-2">{v.title}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-4">Yolculuğumuz</h2>
        <p class="text-lg text-neutral-600">Küçük bir Malatya ofisinden bölgenin lider ajansına.</p>
      </div>
      <div class="space-y-8">
        {milestones.map((m, i) => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="inline-block px-3 py-1 bg-apricot-500 text-white font-bold rounded-lg">{m.year}</span>
            </div>
            <div class="flex-1 pl-6 border-l-2 border-apricot-200 pb-8">
              <h3 class="font-display text-2xl font-bold text-neutral-900 mb-2">{m.title}</h3>
              <p class="text-neutral-700 leading-relaxed">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-apricot-500 to-apricot-600 text-white">
    <div class="container mx-auto px-4 lg:px-8 text-center max-w-3xl">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">Birlikte Çalışalım</h2>
      <p class="text-xl text-apricot-50 mb-8">Markanızın hikayesinin bir sonraki bölümünü birlikte yazalım.</p>
      <a href="/iletisim" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-apricot-600 font-bold text-lg rounded-xl hover:bg-apricot-50 transition-colors">İletişime Geçin</a>
    </div>
  </section>
</BaseLayout>
