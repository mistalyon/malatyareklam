---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: object;
}

const {
  title = 'Malatya Reklam | Reklam, Dijital Pazarlama, Yazılım & E-Ticaret',
  description = 'Malatya\'nın yenilikçi reklam ajansı. Açıkhava reklam, SEO, web tasarım, e-ticaret, kurumsal yazılım ve AI destekli dijital pazarlama çözümleri.',
  ogImage = '/og-image.jpg',
  canonical,
  jsonLd
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || 'https://malatyareklam.com').toString();

const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Malatya Reklam",
  "image": "https://malatyareklam.com/logo.png",
  "url": "https://malatyareklam.com",
  "telephone": "+90-555-123-4567",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Malatya",
    "addressCountry": "TR"
  },
  "priceRange": "₺₺",
  "areaServed": "Malatya"
};
---
<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FF6B35" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="tr_TR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd || defaultJsonLd)} />
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
